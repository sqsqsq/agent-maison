{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://framework.local/harness/summary.schema.json",
  "title": "Framework Harness Run Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "phase",
    "feature",
    "verdict",
    "blocker_count",
    "fail_count",
    "warn_count",
    "script_report",
    "merged_report",
    "ai_prompt",
    "summary_json",
    "run_statuses",
    "readiness_signals",
    "blocking_warnings",
    "blocking_skips",
    "blockers",
    "next_action"
  ],
  "properties": {
    "schema_version": {
      "enum": ["1.0", "1.1"],
      "description": "1.1（blind-visual-hardening d1）：新增 report_validity/quality_axes/release_readiness/completion_status，writer 恒写 1.1；1.0 仅兼容读取，不作 1.1 completion 干净依据（lite 校验器无 if/then，1.1 必填性由代码层强制）"
    },
    "report_validity": {
      "type": "string",
      "enum": ["PASS", "FAIL", "UNVERIFIED"],
      "description": "报告工件可解析/可信——独立于产品裁决（design §1.2），不是产品质量轴"
    },
    "quality_axes": { "$ref": "#/$defs/quality_axes" },
    "release_readiness": { "type": "string", "enum": ["READY", "BLOCKED"] },
    "completion_status": { "type": "string", "minLength": 1 },
    "phase": {
      "type": "string",
      "enum": ["spec", "plan", "prd", "design", "coding", "review", "ut", "testing", "catalog", "glossary", "docs", "init"]
    },
    "feature": { "type": "string", "minLength": 1 },
    "verdict": { "type": "string", "enum": ["PASS", "FAIL", "INCOMPLETE"] },
    "blocker_count": { "type": "integer", "minimum": 0 },
    "fail_count": { "type": "integer", "minimum": 0 },
    "warn_count": { "type": "integer", "minimum": 0 },
    "gate_fingerprint": {
      "type": "string",
      "pattern": "^.+:[0-9a-f]{12}$",
      "description": "门禁集指纹 <frameworkVersion>:<phase-rules sha256 前12>；harness 机器写入，check-receipt 重算比对——framework 升级后旧回执失效（回执 stale 治理）"
    },
    "script_report": { "type": "string", "minLength": 1 },
    "merged_report": { "type": "string", "minLength": 1 },
    "ai_prompt": { "type": "string", "minLength": 1 },
    "summary_json": { "type": "string", "minLength": 1 },
    "run_statuses": {
      "type": "array",
      "items": { "$ref": "#/$defs/run_status" }
    },
    "ut_run_status": { "type": "string" },
    "readiness_signals": {
      "type": "array",
      "items": { "$ref": "#/$defs/readiness_signal" }
    },
    "blocking_warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/blocking_notice" }
    },
    "blocking_skips": {
      "type": "array",
      "items": { "$ref": "#/$defs/blocking_notice" }
    },
    "blockers": {
      "type": "array",
      "items": { "$ref": "#/$defs/blocker" }
    },
    "next_action": { "type": "string", "minLength": 1 },
    "receipt_status": { "type": "string" },
    "closure_status": { "type": "string", "enum": ["open", "closed"] },
    "generated_at": { "type": "string", "description": "t2 v2（receipt-slim）：base summary 生成时刻" },
    "source_commit_sha": { "type": "string", "description": "t2 v2：生成时 git HEAD——slim 回执三方绑定（summary↔receipt claimed↔当前 HEAD），杜绝旧 PASS 件复用" },
    "worktree_digest": { "type": "string", "description": "t2 v3：产品层目录工作区状态摘要——HEAD 不动源码改动同样使旧件失效（check-receipt slim 重算比对）" },
    "run_id": { "type": "string", "description": "t2 v2：goal run 身份（MAISON_GOAL_RUN_ID）" },
    "compile_first_error": { "$ref": "#/$defs/compile_first_error" },
    "soft_advisories": {
      "type": "array",
      "items": { "$ref": "#/$defs/soft_advisory" }
    },
    "visual_round": { "$ref": "#/$defs/visual_round" }
  },
  "$defs": {
    "quality_axes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["functional", "visual", "asset", "evidence"],
      "properties": {
        "functional": { "$ref": "#/$defs/quality_axis" },
        "visual": { "$ref": "#/$defs/quality_axis" },
        "asset": { "$ref": "#/$defs/quality_axis" },
        "evidence": { "$ref": "#/$defs/quality_axis" }
      }
    },
    "quality_axis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applicable", "required_for_release", "verdict", "blocking_class", "source_checks", "resolution"],
      "properties": {
        "applicable": { "type": "boolean" },
        "required_for_release": { "type": "boolean" },
        "verdict": { "type": "string", "enum": ["PASS", "FAIL", "UNVERIFIED", "STALE", "MISSING", "NOT_APPLICABLE"] },
        "blocking_class": { "enum": ["needs_fix", "needs_human", "external_dependency", null] },
        "source_checks": { "type": "array", "items": { "type": "string" } },
        "resolution": {
          "type": ["null", "object"],
          "additionalProperties": false,
          "required": ["class", "owner", "retry_phase"],
          "properties": {
            "class": { "type": "string", "enum": ["needs_fix", "needs_human", "external_dependency"] },
            "owner": { "type": "string", "enum": ["agent", "human", "toolchain", "external"] },
            "retry_phase": { "type": ["null", "string"] }
          }
        }
      }
    },
    "visual_round": {
      "type": "object",
      "additionalProperties": false,
      "required": ["loop_id", "disposition"],
      "description": "t1（plan f7a3d9c2）：视觉轮次账本回执——runner 追加/重放后回传；goal-runner 写入 events.jsonl 做 integrity 对账。duplicate 时同样携带重放后的 decision（rev5）",
      "properties": {
        "loop_id": { "type": "string", "minLength": 1 },
        "attempt": { "type": "string" },
        "row_hash": { "type": "string", "pattern": "^[0-9a-f]{16}$" },
        "disposition": { "type": "string", "enum": ["appended", "duplicate", "append_failed"] },
        "decision": {
          "type": "object",
          "additionalProperties": false,
          "required": ["fused"],
          "properties": {
            "fused": { "type": "boolean" },
            "failure_kind": { "type": "string", "enum": ["no_progress_fuse"] },
            "attribution": { "type": "string", "enum": ["no_fix_attempt", "ineffective_fix"] },
            "residual_fingerprints": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "run_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "details"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["PASS", "FAIL", "WARN", "SKIP"] },
        "can_claim_done": { "type": "boolean" },
        "details": { "type": "string" }
      }
    },
    "readiness_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "message"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["ready", "incomplete", "unknown"] },
        "message": { "type": "string" },
        "source_check": { "type": "string" }
      }
    },
    "blocking_notice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "details_excerpt"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "blocking_class": { "type": "string" },
        "details_excerpt": { "type": "string" },
        "suggestion": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "status", "details_excerpt"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "type": "string" },
        "status": { "type": "string" },
        "classification": { "type": "string" },
        "blocking_class": { "type": "string" },
        "details_excerpt": { "type": "string" },
        "affected_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "suggestion": { "type": "string" },
        "source": {
          "type": "string",
          "description": "t1d（plan e6a3c9f4）：产出来源（safeRun origin / profile dispatch 标签 / check-<phase>.ts 回退）——供 agent 直接定位判定实现"
        }
      }
    },
    "compile_first_error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message"],
      "properties": {
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "message": { "type": "string", "minLength": 1 },
        "kind": { "type": "string" }
      }
    },
    "soft_advisory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "details"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["WARN", "SKIP"] },
        "details": { "type": "string" },
        "effective_image_input": { "type": "string" },
        "source": { "type": "string" }
      }
    }
  }
}
