{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-maison.dev/schemas/ui-spec.schema.json",
  "title": "UI-Spec (UI-DSL)",
  "description": "Structured visual IR produced by spec Step 2; consumed by plan/coding parity gates.",
  "type": "object",
  "required": ["schema_version", "screens", "tokens", "assets"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "verified": {
      "type": "string",
      "enum": ["verified", "unverified", "human_confirmed"],
      "description": "DSL↔原图校验 gate 状态；unverified 时下游 parity 只报结构不报保真。"
    },
    "verified_method": {
      "type": "string",
      "enum": ["vl_multimodal", "human_gate", "none"]
    },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/screen" }
    },
    "tokens": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/definitions/token" }
    },
    "assets": {
      "type": "array",
      "items": { "$ref": "#/definitions/asset" }
    },
    "global_elements": {
      "type": "array",
      "description": "T5：全局元素归属声明（如底部 Tab）；声明后启用 OCR 越界门禁",
      "items": { "$ref": "#/definitions/global_element" }
    }
  },
  "definitions": {
    "global_element": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "texts", "owner_screen_ids"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "texts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "owner_screen_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "band": {
          "type": "object",
          "additionalProperties": false,
          "required": ["start"],
          "properties": {
            "start": { "type": "number", "minimum": 0, "maximum": 1 },
            "end": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "bbox": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "type": "number", "minimum": 0, "maximum": 1 },
      "description": "归一化 [x, y, w, h] 相对原图 ground truth。顺序严格为 [横向x, 纵向y, 宽w, 高h]，绝非 [y,x,h,w]。few-shot：竖屏左上角标题「钱包」≈ [0.04, 0.02, 0.30, 0.05]（x 小、y 小、w 明显大于 h——横排文本恒 w>h）；页面中部横向 hero 插画 ≈ [0.08, 0.15, 0.84, 0.20]。自检：横排多字文本若算出 w<h 即坐标顺序写反（门禁 ui_spec_bbox_semantic 会系统性拦截）"
    },
    "componentNode": {
      "type": "object",
      "required": ["type", "order"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "input",
            "action_button",
            "overlay_panel",
            "navigation_frame",
            "content_display",
            "list_selection",
            "logic_condition"
          ]
        },
        "layout": { "type": "string" },
        "order": { "type": "integer", "minimum": 0 },
        "text": { "type": "string" },
        "data_binding": { "type": "string" },
        "style_ref": { "type": "string" },
        "asset_ref": { "type": "string" },
        "bbox": { "$ref": "#/definitions/bbox" },
        "variant": {
          "type": "string",
          "enum": ["filled", "tonal", "outlined", "ghost", "text"],
          "description": "G3：按钮视觉变体（治实心蓝 vs 浅灰药丸/幽灵按钮）"
        },
        "layout_group": {
          "type": "string",
          "description": "G3：同行/同容器布局分组 id（同一 id 元素在同一行）"
        },
        "align": {
          "type": "string",
          "enum": ["start", "center", "end", "space_between", "stretch"],
          "description": "G3：主轴对齐"
        },
        "width_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "G3：宽度占比 0–1（治全宽 vs 右侧药丸）"
        },
        "bg_color": {
          "type": "string",
          "description": "G3：区域/容器背景色 token（治灰底 vs 蓝底）"
        },
        "fidelity_note": {
          "type": "string",
          "description": "P0-E：受控近似的显式承认（如「原图彩色线性图标，以 system_symbol+color_ref 着色近似」）"
        },
        "subtitle": {
          "type": "string",
          "description": "P0-D：list_row 副标题文本（副标题建模在主节点上，禁独立平铺节点）"
        },
        "subtitle_position": {
          "type": "string",
          "enum": ["trailing", "below"],
          "description": "P0-D：副标题位置——trailing=与主标题同行右置 / below=题下；pixel_1to1 P0 屏有 subtitle 必填（门禁 ui_spec_structure_lint）"
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/definitions/componentNode" }
        }
      }
    },
    "screen": {
      "type": "object",
      "required": ["id", "priority"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
        "ref_id": { "type": "string" },
        "root": { "$ref": "#/definitions/componentNode" },
        "lightweight": {
          "type": "boolean",
          "description": "P2/P3 轻量版：可省略细粒度组件树与 bbox"
        }
      }
    },
    "token": {
      "type": "object",
      "required": ["kind", "value"],
      "properties": {
        "kind": { "type": "string", "enum": ["color", "spacing", "font_size", "radius", "divider"] },
        "value": { "type": "string" },
        "source_bbox": { "$ref": "#/definitions/bbox" },
        "sampled": {
          "type": "boolean",
          "description": "true 表示 value 由脚本像素采样（半确定性）"
        }
      }
    },
    "asset": {
      "type": "object",
      "required": ["key", "acquisition"],
      "properties": {
        "key": { "type": "string" },
        "acquisition": { "type": "string", "enum": ["crop", "svg_grab", "repo_ref"] },
        "source_ref": { "type": "string" },
        "source_bbox": { "$ref": "#/definitions/bbox" },
        "resolved_path": { "type": "string" },
        "placeholder": { "type": "boolean" },
        "rationale": { "type": "string" },
        "human_crop_confirmed": { "type": "boolean" },
        "crop_confirmed_by": { "type": "string", "description": "G4b：crop 裁剪**授权**来源；headless 下须为非自动化身份或 user_requirement（堵自报）。授权≠验真：产物验真见 asset_crop_validation 与 bbox_verified_by" },
        "baked_text_defer": { "type": "boolean", "description": "round5 P0-A：显式放行素材图内含声明文本（营销/装饰插画确需含字）" },
        "baked_text_defer_by": { "type": "string", "description": "round5 P0-A：baked_text_defer 真人署名（非自动化身份）；缺则 defer 无效" },
        "bbox_verified_by": { "type": "string", "description": "P0-C：crop 产物验真的真人确认署名（对照 contact-sheet）；与授权正交，是 VL 辨认不可用/失配时的唯一逃生阀（自动化身份不算）" }
      }
    }
  }
}
