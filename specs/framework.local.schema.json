{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://framework.local/schemas/framework.local.json",
  "title": "framework.local.json",
  "description": "Personal (gitignored) settings per developer machine; merged at runtime by harness/config.ts",
  "type": "object",
  "required": ["schema_version"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "agent_adapter": {
      "type": "string",
      "description": "Active adapter for this developer (must be in project materialized_adapters when set)"
    },
    "toolchain": {
      "type": "object",
      "properties": {
        "devEcoStudio": {
          "type": "object",
          "properties": {
            "installPath": { "type": "string" },
            "hvigorBin": { "type": "string" }
          },
          "additionalProperties": false
        },
        "probe": {
          "type": "object",
          "description": "t6 toolchain-probe-truth（plan e6a3c9f4）：机器探测快照。写入权限固定——binary/cli_starts 由 check-personal-setup --ensure 更新；project_compile 的 verified/capability_failed 仅 hvigor wrapper 真实结果写入（agent 声明/手编不升级状态）；--ensure 人工 reprobe 仅可把 capability_failed 降级重置为 unknown（v4，绝不升级）；known_quirks 纯人读，永不参与 gate 判定。",
          "properties": {
            "binary": {
              "type": "object",
              "properties": {
                "hvigor_bin": { "type": "string" },
                "observed_at": { "type": "string" }
              },
              "additionalProperties": false
            },
            "cli_starts": {
              "type": "object",
              "properties": {
                "ok": { "type": "boolean" },
                "hvigor_version": { "type": "string" },
                "observed_at": { "type": "string" }
              },
              "additionalProperties": false
            },
            "project_compile": {
              "type": "object",
              "required": ["status"],
              "properties": {
                "status": { "type": "string", "enum": ["unknown", "verified", "capability_failed"] },
                "failure_code": { "type": ["string", "null"] },
                "evidence": { "type": "array", "items": { "type": "string" } },
                "invocation_fingerprint": { "type": "string" },
                "config_digest": { "type": "string", "description": "工程配置/依赖锁定态摘要——变更即状态自动失效回 unknown（preflight 可独立重算比对）" },
                "observed_at": { "type": "string" },
                "expires_at": { "type": "string" },
                "recovery_probe_pending": { "type": "boolean", "description": "已废弃（v4）：授予模型移除——capability_failed 恒拦截，解除仅靠配置漂移自动失效 / --ensure 人工 reprobe / wrapper 真实编译改写。保留仅为兼容旧 local 文件，任何逻辑不再读取。" },
                "integrity": { "type": "string", "description": "载荷完整性摘要（防手滑/威慑，非密码学）；失配按 unknown 处理——伪造不通过任何 gate" }
              },
              "additionalProperties": false
            },
            "last_attempt": {
              "type": "object",
              "description": "人读留痕（普通源码编译失败等）；不参与任何判定",
              "properties": {
                "summary": { "type": "string" },
                "observed_at": { "type": "string" }
              },
              "additionalProperties": false
            },
            "known_quirks": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "vision": {
      "type": "object",
      "description": "Multimodal capability descent ladder (plan d4a8f3c6 / b7e42d19); written silently by the canary probe, never hand-edited",
      "properties": {
        "image_input_override": {
          "type": "string",
          "enum": ["none", "tool_read", "native_attach"],
          "description": "User explicit override; skips capability probe entirely"
        },
        "canary": {
          "type": "object",
          "description": "Visual-capability canary probe result cache",
          "required": ["adapter", "verdict", "probed_at"],
          "properties": {
            "adapter": { "type": "string" },
            "verdict": {
              "type": "string",
              "enum": ["tool_read", "ocr_capable", "none"]
            },
            "probed_at": { "type": "string" },
            "reason": { "type": "string" },
            "probed_via": {
              "type": "string",
              "enum": ["goal", "interactive"],
              "description": "Probe origin; absent treated as 'goal' (backward compat)"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
