{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://framework.local/schemas/framework.config.json",
  "title": "framework.config.json",
  "description": "实例工程根目录 framework.config.json 的结构化描述（project_name 为实例名）；权威解析与默认合并逻辑见 framework/harness/config.ts",
  "type": "object",
  "required": ["schema_version", "project_name", "architecture", "paths"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "实例 DSL schema 版本；1.1 起包含 workflow/extensions/hooks 默认字段语义。"
    },
    "project_name": { "type": "string" },
    "project_type": {
      "type": "string",
      "enum": ["app", "atomic_service"],
      "description": "Deprecated：仅存 alias；权威子型请写 project_profile.sub_variant（element-service = 原 atomic_service）"
    },
    "project_profile": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "description": "对应 framework/profiles/<name>/" },
        "sub_variant": { "type": "string" }
      },
      "additionalProperties": false
    },
    "agent_adapter": {
      "type": "string",
      "description": "Deprecated in project config: use framework.local.json. Kept for legacy migration."
    },
    "materialized_adapters": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Project-level list of adapter artifacts to materialize (claude, cursor, generic)"
    },
    "architecture": { "type": "object" },
    "paths": {
      "type": "object",
      "properties": {
        "features_dir": { "type": "string" },
        "module_catalog": { "type": "string" },
        "glossary": { "type": "string" },
        "glossary_seed": { "type": "string" },
        "architecture_md": { "type": "string" },
        "state_file": { "type": "string" },
        "receipt_dir_pattern": { "type": "string" },
        "docs_committed": { "type": "boolean" },
        "extension_dir": {
          "type": "string",
          "description": "实例扩展根目录（相对实例工程根），默认 doc/extensions。"
        },
        "agent_bundle_root": {
          "type": "string",
          "description": "generic adapter：agent bundle 根目录（相对实例工程根），如 .agents。"
        },
        "agent_bundle_skill_mode": {
          "type": "string",
          "enum": ["bridge", "inline"],
          "description": "generic adapter：bundle 内 skills 物化方式；默认 bridge。"
        }
      },
      "additionalProperties": true
    },
    "toolchain": {
      "type": "object",
      "properties": {
        "hmosDevice": {
          "type": "object",
          "properties": {
            "killHdcServerOnFinish": { "type": "boolean" },
            "aaTestTimeoutMs": { "type": "number", "minimum": 1 },
            "testRunner": { "type": "string" }
          },
          "additionalProperties": false
        },
        "hvigor": { "type": "object" },
        "preferredProduct": { "type": "string" }
      },
      "additionalProperties": true
    },
    "tools": { "type": "object" },
    "state_machine": { "type": "object" },
    "spec": {
      "type": "object",
      "description": "spec 阶段 opt-in 脚本行为（如 visual_handoff_enforcement / visual_sources）。"
    },
    "active_workflow": {
      "type": "string",
      "description": "framework/workflows/<name>.workflow.yaml 的 stem；默认 spec-driven。"
    },
    "lifecycle_hooks_enabled": {
      "type": "boolean",
      "description": "是否运行 lifecycle hooks（framework/profile/extension）；默认 true。"
    }
  },
  "additionalProperties": true
}
